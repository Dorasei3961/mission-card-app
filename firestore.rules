rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function eventDoc(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function isEventActive(eventId) {
      return eventExists(eventId) && eventDoc(eventId).data.status != "closed";
    }

    function isEventOwner(eventId) {
      return isSignedIn()
        && eventExists(eventId)
        && eventDoc(eventId).data.ownerUid == request.auth.uid;
    }

    function adminSessionPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId)/adminSessions/$(request.auth.uid);
    }

    function isEventAdmin(eventId) {
      return isSignedIn()
        && eventExists(eventId)
        && exists(adminSessionPath(eventId))
        && get(adminSessionPath(eventId)).data.authUid == request.auth.uid
        && get(adminSessionPath(eventId)).data.expiresAt > request.time;
    }

    function canManageEvent(eventId) {
      return isEventOwner(eventId) || isEventAdmin(eventId);
    }

    function canManageActiveEvent(eventId) {
      return canManageEvent(eventId) && isEventActive(eventId);
    }

    match /events/{eventId} {
      // events は公開読み取り
      allow read: if true;

      // 作成時は ownerUid = 自分
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == "active";

      // イベント本体: 運営PINセッション or owner
      allow update: if canManageEvent(eventId);
      allow delete: if canManageEvent(eventId) && isEventActive(eventId);

      // 運営PIN認証セッション（API の Admin SDK のみ作成。クライアントからの直接書き込み不可）
      match /adminSessions/{authUid} {
        allow read: if isSignedIn() && request.auth.uid == authUid;
        allow create, update: if false;
        allow delete: if isSignedIn() && request.auth.uid == authUid;
      }

      // 参加者
      match /participants/{participantId} {
        allow read: if true;

        allow create: if isSignedIn()
          && isEventActive(eventId)
          && (
            canManageEvent(eventId)
            || participantId == request.auth.uid
            || (
              request.resource.data.authUid is string
              && request.resource.data.authUid == request.auth.uid
            )
          );

        allow update: if isSignedIn()
          && isEventActive(eventId)
          && (
            canManageEvent(eventId)
            || participantId == request.auth.uid
            || (
              request.resource.data.authUid is string
              && request.resource.data.authUid == request.auth.uid
            )
          );

        allow delete: if canManageActiveEvent(eventId);
      }

      match /missionProgress/{progressId} {
        allow read: if isSignedIn()
          && (
            canManageEvent(eventId)
            || progressId == request.auth.uid
            || resource == null
            || (
              resource.data.authUid is string
              && resource.data.authUid == request.auth.uid
            )
            || (
              resource.data.userId is string
              && resource.data.userId == request.auth.uid
            )
          );

        allow create, update: if isSignedIn()
          && isEventActive(eventId)
          && (
            canManageEvent(eventId)
            || progressId == request.auth.uid
            || (
              request.resource.data.authUid is string
              && request.resource.data.authUid == request.auth.uid
            )
          );

        allow delete: if canManageActiveEvent(eventId);
      }

      match /pointLogs/{logId} {
        allow read: if true;
        allow create: if isSignedIn()
          && isEventActive(eventId)
          && (
            canManageEvent(eventId)
            || (
              request.resource.data.uid is string
              && request.resource.data.uid == request.auth.uid
            )
          );
        allow update, delete: if false;
      }

      match /missions/{missionId} {
        allow read: if true;
        allow create, update, delete: if canManageActiveEvent(eventId);
      }

      match /quizzes/{quizId} {
        allow read: if true;
        allow create, update, delete: if canManageActiveEvent(eventId);
      }

      match /quizAnswers/{answerId} {
        allow read: if true;
        allow create: if isSignedIn()
          && isEventActive(eventId)
          && request.resource.data.participantId == request.auth.uid
          && request.resource.data.quizId is string
          && request.resource.data.selectedIndex is int;
        allow update, delete: if false;
      }

      match /quiz/{docId} {
        allow read: if true;
        allow create, update, delete: if canManageActiveEvent(eventId);
      }

      match /bingoSettings/{docId} {
        allow read: if true;
        allow create, update, delete: if canManageActiveEvent(eventId);
      }

      match /bingoState/{docId} {
        allow read: if true;
        allow create, update: if canManageActiveEvent(eventId)
          || (isSignedIn() && isEventActive(eventId));
        allow delete: if canManageActiveEvent(eventId);
      }

      match /bingoCards/{cardId} {
        allow read: if true;
        allow create, update: if isSignedIn() && isEventActive(eventId);
        allow delete: if canManageActiveEvent(eventId);
      }

      match /bingoDrawLogs/{logId} {
        allow read: if true;
        allow create: if canManageActiveEvent(eventId);
        allow update, delete: if false;
      }

      match /rouletteSettings/{docId} {
        allow read: if true;
        allow create, update, delete: if canManageActiveEvent(eventId);
      }

      match /rouletteState/{docId} {
        allow read: if true;
        allow create, update: if isSignedIn() && isEventActive(eventId);
        allow delete: if canManageActiveEvent(eventId);
      }

      match /rouletteItems/{itemId} {
        allow read: if true;
        allow create, delete: if canManageActiveEvent(eventId);
        allow update: if canManageActiveEvent(eventId)
          || (
            isSignedIn()
            && isEventActive(eventId)
            && resource.data.active == true
            && request.resource.data.active == false
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active', 'updatedAt'])
          );
      }

      match /rouletteHistory/{historyId} {
        allow read: if true;
        allow create: if isSignedIn() && isEventActive(eventId);
        allow delete: if canManageActiveEvent(eventId);
        allow update: if false;
      }
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
